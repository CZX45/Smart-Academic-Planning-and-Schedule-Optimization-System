# Local development PostgreSQL defaults. These are not real school credentials.
POSTGRES_USER=sapsos
POSTGRES_PASSWORD=sapsos_dev_password
POSTGRES_DB=sapsos

# Local FastAPI database URL for Docker PostgreSQL + local API development.
DATABASE_URL=postgresql+psycopg://sapsos:sapsos_dev_password@localhost:5432/sapsos
DATABASE_CONNECT_TIMEOUT_SECONDS=3

# FastAPI host/port for local development.
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated browser origins allowed to call the local API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public API URL used by the Next.js frontend in local development.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
