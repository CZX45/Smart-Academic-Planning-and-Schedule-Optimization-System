{
  "openapi": "3.1.0",
  "info": {
    "title": "Smart Academic Planning API",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Ready",
        "operationId": "ready_ready_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "examples": [
              "ok"
            ]
          },
          "service": {
            "type": "string",
            "title": "Service"
          },
          "database_configured": {
            "type": "boolean",
            "title": "Database Configured"
          }
        },
        "type": "object",
        "required": [
          "status",
          "service",
          "database_configured"
        ],
        "title": "HealthResponse"
      },
      "ReadinessResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "examples": [
              "ready",
              "not_ready"
            ]
          },
          "service": {
            "type": "string",
            "title": "Service"
          },
          "database_ready": {
            "type": "boolean",
            "title": "Database Ready"
          }
        },
        "type": "object",
        "required": [
          "status",
          "service",
          "database_ready"
        ],
        "title": "ReadinessResponse"
      }
    }
  }
}
