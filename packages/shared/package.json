{
  "name": "@sapsos/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --check \"src/**/*.ts\" \"scripts/**/*.mjs\" eslint.config.js package.json tsconfig.json",
    "generate": "node scripts/generate-openapi-types.mjs"
  },
  "dependencies": {
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.16",
    "prettier": "^3.7.4"
  }
}
