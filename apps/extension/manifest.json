{
  "manifest_version": 3,
  "name": "SAPSOS Read-only Import Assistant",
  "version": "0.1.0",
  "description": "User-triggered visible-page extraction into staging imports.",
  "action": {
    "default_title": "SAPSOS Import",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [],
  "optional_host_permissions": ["https://kean-ss.colleague.elluciancloud.com/*"]
}
