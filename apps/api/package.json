{
  "name": "@sapsos/api",
  "version": "0.1.6",
  "private": true,
  "scripts": {
    "dev": "python -m app.run",
    "lint": "python -m ruff check .",
    "test": "python -m pytest",
    "typecheck": "python -m mypy .",
    "format": "python -m ruff format --check .",
    "openapi": "python -m app.openapi_export",
    "package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/windows/Build-FastAPI-Runtime.ps1",
    "build": "python -m compileall app"
  }
}
